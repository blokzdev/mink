# Release signing configuration for Mink.
#
# Copy this file to `keystore.properties` (which is gitignored) and fill in the
# real values to produce a distributable, release-signed APK/AAB. Without it,
# `./gradlew :app:assembleRelease` still works but signs with the debug key —
# fine for local testing, never for distribution.
#
# Generate a keystore once with:
#   keytool -genkey -v -keystore mink-release.jks -alias mink \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# Keep the .jks file and this file OUT of version control (see .gitignore).

storeFile=../mink-release.jks
storePassword=CHANGE_ME
keyAlias=mink
keyPassword=CHANGE_ME
