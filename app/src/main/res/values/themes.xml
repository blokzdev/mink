<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose owns the runtime theme; this is the launch/system-bar theme.
         Edge-to-edge is enabled in code via enableEdgeToEdge(). -->
    <style name="Theme.Mink" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/mink_ink</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
