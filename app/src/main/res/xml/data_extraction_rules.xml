<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="models/" />
        <exclude domain="database" path="guardian.db" />
        <exclude domain="sharedpref" path="guardian_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="models/" />
    </device-transfer>
</data-extraction-rules>
