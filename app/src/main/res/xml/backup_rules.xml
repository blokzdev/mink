<?xml version="1.0" encoding="utf-8"?>
<!-- Mink keeps everything on-device. Exclude the guardian's model cache and
     its private datastore (Preferences DataStore writes to
     files/datastore/<name>.preferences_pb) from cloud backup so nothing
     sensitive leaves. -->
<full-backup-content>
    <exclude domain="file" path="models/" />
    <exclude domain="file" path="datastore/guardian.preferences_pb" />
</full-backup-content>
